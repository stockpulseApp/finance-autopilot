# Site
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=Finance Autopilot

# Daily AI blog generation — Anthropic Claude (scripts/generate-daily-post.mjs)
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Sonnet = best quality; Haiku = cheaper for daily posts
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Newsletter (ConvertKit example — wire in src/lib/newsletter.ts)
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Stripe courses (optional — wire checkout in src/lib/stripe.ts)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Affiliate IDs (replace YOUR_ID with network IDs)
NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=
AFFILIATE_DISCLOSURE_ENABLED=true
